<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <!-- Back button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        app:layout_anchor="@id/scrollView"
        android:elevation="8dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="48dp"
        android:layout_marginStart="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="←"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/text_primary"/>
    </androidx.cardview.widget.CardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="80dp"
                android:paddingBottom="28dp">

                <!-- Tag + source row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvDetailTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Philosophy"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvDetailSource"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Substack"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:background="@drawable/bg_source_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Color divider accent line -->
                <View
                    android:id="@+id/dividerTagAccent"
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="14dp"
                    android:background="@color/accent_green"/>

                <!-- Title -->
                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The Attention Economy Is Eating Itself"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.25"
                    android:layout_marginTop="10dp"/>

                <!-- Author -->
                <TextView
                    android:id="@+id/tvDetailAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="by L.M. Sacasas"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"/>

                <!-- Meta row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tvDetailDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read on May 8, 2025"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"/>

                    <TextView
                        android:id="@+id/tvDetailReadingTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 min read"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"/>
                </LinearLayout>

                <!-- Rating + mood -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp">

                    <RatingBar
                        android:id="@+id/ratingBarDetail"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:isIndicator="true"
                        android:progressTint="@color/accent_green"/>

                    <TextView
                        android:id="@+id/tvDetailRatingNum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.5 / 5.0"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="6dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvDetailMood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thought-provoking"
                        android:textSize="11sp"
                        android:textColor="@color/accent_green"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="40dp">

                <!-- TL;DR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TL;DR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvDetailSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Summary goes here."
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.6"
                    android:fontFamily="serif"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_summary_block"
                    android:padding="16dp"/>

                <!-- Full review -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MY REVIEW"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="28dp"/>

                <TextView
                    android:id="@+id/tvDetailReview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Full review goes here."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.7"
                    android:layout_marginTop="10dp"/>

                <!-- Key takeaways card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/accent_green_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KEY TAKEAWAYS"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_green"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/tvTakeaways"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Takeaways here."
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.6"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Recommended for -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECOMMENDED FOR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp"/>

                <TextView
                    android:id="@+id/tvRecommendedFor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recommended for goes here."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

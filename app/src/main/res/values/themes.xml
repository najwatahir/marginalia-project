<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ArticleReview" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ArticleReview.Splash" parent="Theme.ArticleReview">
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/bg_cream</item>
    </style>
</resources>
